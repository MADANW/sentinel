# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env — IT IS IN .gitignore
# ============================================================

# ---- Environment ----
# Must be explicitly set to "live" to trade real money.
# Anything else (paper, dev, test) uses Alpaca paper trading.
TRADING_ENV=paper

# ---- Alpaca ----
# Get these from https://alpaca.markets → Account → API Keys
# Use PAPER keys for TRADING_ENV=paper, LIVE keys for TRADING_ENV=live
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Paper base URL (leave as-is for paper trading)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Live: https://api.alpaca.markets

# ---- Anthropic Claude ----
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---- Supabase ----
# Get from https://supabase.com → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key — ONLY used server-side, NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Dashboard (Next.js) ----
# Public vars exposed to browser — must be prefixed NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
