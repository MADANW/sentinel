# Direct dependencies only — transitive deps are resolved by pip-compile.
#
# To regenerate requirements.txt with verified hashes:
#   pip install pip-tools
#   pip-compile backend/requirements.in --generate-hashes --output-file backend/requirements.txt
#
# After regeneration, install with hash verification:
#   pip install --require-hashes -r backend/requirements.txt

