# ============================================================
# Copy this to .env.local — NEVER commit .env.local
# ============================================================

# ── Supabase (server-side only) ──────────────────────────────────────────────
# Service role key has full DB access — never expose to the browser.
# Used by createServerClient() in lib/supabase.ts.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase (public, browser-safe) ─────────────────────────────────────────
# Anon key only — safe to expose. Required if adding any client components.
# Do NOT add the service role key here.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Display-only (never the broker API credentials) ──────────────────────────
# Account number is shown in the header for identification purposes only.
# NEVER add ALPACA_API_KEY or ALPACA_SECRET_KEY here — the dashboard is read-only.
ALPACA_ACCOUNT_NUMBER=PA1234567890

# ── Trading environment ───────────────────────────────────────────────────────
# Drives the PAPER / LIVE mode badge in the header.
TRADING_ENV=paper

# ── Equity display ────────────────────────────────────────────────────────────
# Updated by the backend pipeline after each run; dashboard reads and displays it.
# Format: numeric string, e.g. "100000" or "100000.00"
ALPACA_PAPER_EQUITY=100000
